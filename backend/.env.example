# Copy to .env in this folder (backend/.env) and fill in values.
# Alternative: backend/src/.env is also loaded if present.

MONGO_URI=mongodb://127.0.0.1:27017/meritnook
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Optional: frontend URL(s) for CORS (comma-separated for CLIENT_URLS)
# CLIENT_URL=http://localhost:5173
